{
  "python.defaultInterpreterPath": "${workspaceFolder}/classes exercises/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true,
  "jupyter.kernels.excludePythonEnvironments": [],
  "jupyter.kernels.filter": [],
  "notebook.kernelProviderAssociations": [
    {
      "viewType": "jupyter-notebook",
      "kernelProvider": "ms-toolsai.jupyter"
    }
  ],

  "editor.inlineSuggest.enabled": true,
  "editor.tabCompletion": "on",
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.suggest.preview": true,
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.cpp.disabledLanguages": ["markdown", "plaintext", "scminput"],

  "[python]": {
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "off",
      "strings": "on"
    },
    "editor.tabCompletion": "on",
    "editor.suggest.snippetsPreventQuickSuggestions": false
  },

  "jupyter.enableExtendedPythonKernelCompletions": true,
  "jupyter.interactiveWindow.textEditor.executeSelection": false,
  "notebook.lineNumbers": "on",

  "workspaceKeybindings.tabCompletion.enabled": true
}
